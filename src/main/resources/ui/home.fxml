<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/23"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="app.shell.HomeController"
            styleClass="app-root">

    <center>
        <StackPane>
            <VBox spacing="14"
                  alignment="TOP_CENTER"
                  StackPane.alignment="TOP_CENTER"
                  style="-fx-padding: 28 0 0 0;">

                <Label text="Выберите раздел" styleClass="hero-subtitle"/>

                <VBox spacing="12" alignment="CENTER">
                    <Button text="Test Cases"  onAction="#openTestCases"  prefWidth="320" prefHeight="56" styleClass="product-button"/>
                    <Button text="Cycles"      onAction="#openCycles"     prefWidth="320" prefHeight="56" styleClass="product-button"/>
                    <Button text="History"     onAction="#openHistory"    prefWidth="320" prefHeight="56" styleClass="product-button"/>
                    <Button text="Analytics"   onAction="#openAnalytics"  prefWidth="320" prefHeight="56" styleClass="product-button"/>
                    <Button text="Reports"     onAction="#openReports"    prefWidth="320" prefHeight="56" styleClass="product-button"/>
                </VBox>
            </VBox>
        </StackPane>
    </center>
</BorderPane>
