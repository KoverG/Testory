<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/23"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="app.shell.HomeController"
            styleClass="app-root">

    <center>
        <StackPane>
            <VBox spacing="14"
                  alignment="TOP_CENTER"
                  StackPane.alignment="TOP_CENTER"
                  style="-fx-padding: 28 0 0 0;">

                <Label text="%home.chooseSection" styleClass="hero-subtitle"/>

                <VBox spacing="12" alignment="CENTER" styleClass="product-nav">
                    <Button fx:id="btnTestCases"  text="%view.testCases"  onAction="#openTestCases"  prefWidth="320" prefHeight="56" styleClass="product-button"/>
                    <Button fx:id="btnCycles"     text="%view.cycles"     onAction="#openCycles"     prefWidth="320" prefHeight="56" styleClass="product-button"/>
                    <Button fx:id="btnHistory"    text="%view.history"    onAction="#openHistory"    prefWidth="320" prefHeight="56" styleClass="product-button"/>
                    <Button fx:id="btnReports"    text="%view.reports"    onAction="#openReports"    prefWidth="320" prefHeight="56" styleClass="product-button"/>
                    <StackPane fx:id="analyticsButtonHost" prefWidth="320" maxWidth="320">
                        <Button fx:id="btnAnalytics"  text="%view.analytics"  onAction="#openAnalytics"  prefWidth="320" prefHeight="56" maxWidth="320" styleClass="product-button"/>
                    </StackPane>
                </VBox>
            </VBox>
        </StackPane>
    </center>
</BorderPane>
