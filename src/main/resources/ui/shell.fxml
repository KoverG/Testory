<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<StackPane xmlns="http://javafx.com/javafx/23"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="app.shell.ShellController"
           fx:id="rootStack"
           styleClass="app-root">

    <!-- ===== ОСНОВНОЙ КАРКАС (Router меняет center) ===== -->
    <BorderPane fx:id="appRoot" styleClass="app-root">
        <top>
            <VBox fx:id="topBar">
                <HBox spacing="12" styleClass="app-header">
                    <!-- Menu слева -->
                    <Button fx:id="btnMenu"
                            onAction="#toggleMenu"
                            focusTraversable="false"
                            styleClass="icon-btn,sm"
                            accessibleText="Menu"/>

                    <Label fx:id="title" styleClass="app-title emboss"/>
                    <Label text="beta" styleClass="accent-chip"/>

                    <Pane HBox.hgrow="ALWAYS"/>

                    <Label fx:id="lblHeaderScreen" styleClass="screen-title"/>

                    <!-- Settings справа -->
                    <Button fx:id="btnSettings"
                            onAction="#toggleSettingsDrawer"
                            focusTraversable="false"
                            styleClass="icon-btn,sm"
                            accessibleText="Settings"/>
                </HBox>

                <!-- красная линия -->
                <Pane styleClass="fheader-accent"/>
            </VBox>
        </top>

        <center>
            <StackPane/>
        </center>

        <bottom>
            <VBox>
                <Pane styleClass="ffooter-accent"/>
                <HBox spacing="16" styleClass="footer">
                    <Label fx:id="lblVersion" styleClass="footer-left"/>
                    <Pane HBox.hgrow="ALWAYS"/>
                    <Label fx:id="lblScreenName" styleClass="footer-right"/>
                </HBox>
            </VBox>
        </bottom>
    </BorderPane>

    <!-- ===== OVERLAY: покрывает ТОЛЬКО контент (не шапку) ===== -->
    <Pane fx:id="drawerOverlay"
          visible="false"
          managed="true"
          styleClass="drawer-overlay"
          StackPane.alignment="TOP_LEFT"
          onMouseClicked="#closeAnyDrawer"/>

    <!-- ===== DRAWER слева ===== -->
    <VBox fx:id="drawer"
          visible="false"
          managed="true"
          styleClass="drawer"
          StackPane.alignment="TOP_LEFT"
          onMouseClicked="#consumeInsideDrawer"
          prefWidth="170" minWidth="170" maxWidth="170">

        <VBox spacing="8"
              styleClass="drawer-nav"
              fillWidth="true">

            <Button text="Home"       onAction="#navHome"       styleClass="drawer-item" maxWidth="Infinity"/>
            <Button text="Test Cases" onAction="#navTestCases"  styleClass="drawer-item" maxWidth="Infinity"/>
            <Button text="Cycles"     onAction="#navCycles"     styleClass="drawer-item" maxWidth="Infinity"/>
            <Button text="History"    onAction="#navHistory"    styleClass="drawer-item" maxWidth="Infinity"/>
            <Button text="Analytics"  onAction="#navAnalytics"  styleClass="drawer-item" maxWidth="Infinity"/>
            <Button text="Reports"    onAction="#navReports"    styleClass="drawer-item" maxWidth="Infinity"/>
        </VBox>

        <!-- пустая область тоже часть панели -->
        <Region VBox.vgrow="ALWAYS"/>
    </VBox>

    <!-- ===== DRAWER справа (Settings) ===== -->
    <VBox fx:id="settingsDrawer"
          visible="false"
          managed="true"
          styleClass="drawer,drawer-right"
          StackPane.alignment="TOP_RIGHT"
          onMouseClicked="#consumeInsideDrawer"
          prefWidth="240" minWidth="240" maxWidth="240">

        <VBox spacing="8"
              styleClass="drawer-nav"
              fillWidth="true">

            <Button text="Settings…"   onAction="#openSettings"     styleClass="drawer-item" maxWidth="Infinity"/>
            <Button text="Edit Mode"   onAction="#openEditMode"     styleClass="drawer-item" maxWidth="Infinity"/>
            <Button text="About"       onAction="#openAbout"        styleClass="drawer-item" maxWidth="Infinity"/>
        </VBox>

        <Region VBox.vgrow="ALWAYS"/>
    </VBox>

</StackPane>
