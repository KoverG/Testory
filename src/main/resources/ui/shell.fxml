<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>
<?import app.ui.ToggleSwitch?>

<StackPane xmlns="http://javafx.com/javafx/23"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="app.shell.ShellController"
           fx:id="rootStack"
           styleClass="app-root">

    <BorderPane fx:id="frame" styleClass="app-root">

        <!-- ================= HEADER ================= -->
        <top>
            <VBox fx:id="topBar">
                <HBox spacing="12" styleClass="app-header">
                    <Button fx:id="btnMenu"
                            onAction="#toggleMenu"
                            focusTraversable="false"
                            styleClass="icon-btn,sm"/>

                    <!-- BACK (скрыта на HOME и когда нет истории) -->
                    <Button fx:id="btnBack"
                            onAction="#navBack"
                            focusTraversable="false"
                            visible="false"
                            managed="false"
                            styleClass="icon-btn,sm,wide,danger"/>

                    <Label fx:id="title" id="title" text="Testory"/>

                    <Region HBox.hgrow="ALWAYS"/>

                    <Label fx:id="lblHeaderScreen"
                           text="%view.home"
                           styleClass="screen-title"/>

                    <Button fx:id="btnSettings"
                            onAction="#toggleSettingsDrawer"
                            focusTraversable="false"
                            styleClass="icon-btn,sm"/>
                </HBox>

                <Region styleClass="fheader-accent"/>
            </VBox>
        </top>

        <!-- ================= CONTENT ================= -->
        <center>
            <StackPane fx:id="contentStack" styleClass="app-root">

                <BorderPane fx:id="appRoot" styleClass="app-root">
                    <center>
                        <StackPane/>
                    </center>
                </BorderPane>

                <Pane fx:id="drawerOverlay"
                      visible="false"
                      managed="true"
                      styleClass="drawer-overlay"
                      StackPane.alignment="TOP_LEFT"
                      onMouseClicked="#closeAnyDrawer"/>

                <!-- левый drawer -->
                <VBox fx:id="drawer"
                      visible="false"
                      managed="true"
                      styleClass="drawer"
                      StackPane.alignment="TOP_LEFT"
                      onMouseClicked="#consumeInsideDrawer"
                      prefWidth="240" minWidth="240" maxWidth="240">

                    <VBox spacing="8"
                          styleClass="drawer-nav"
                          fillWidth="true">
                        <VBox.margin>
                            <Insets top="0" right="0" bottom="0" left="0"/>
                        </VBox.margin>

                        <Button text="%view.home"       onAction="#navHome"      styleClass="drawer-item" maxWidth="Infinity"/>
                        <Button text="%view.testCases"  onAction="#navTestCases" styleClass="drawer-item" maxWidth="Infinity"/>
                        <Button text="%view.cycles"     onAction="#navCycles"    styleClass="drawer-item" maxWidth="Infinity"/>
                        <Button text="%view.history"    onAction="#navHistory"   styleClass="drawer-item" maxWidth="Infinity"/>
                        <Button text="%view.analytics"  onAction="#navAnalytics" styleClass="drawer-item" maxWidth="Infinity"/>
                        <Button text="%view.reports"    onAction="#navReports"   styleClass="drawer-item" maxWidth="Infinity"/>
                    </VBox>

                    <Region VBox.vgrow="ALWAYS"/>
                </VBox>

                <!-- правый drawer -->
                <VBox fx:id="settingsDrawer"
                      visible="false"
                      managed="true"
                      styleClass="drawer,drawer-right"
                      StackPane.alignment="TOP_RIGHT"
                      onMouseClicked="#consumeInsideDrawer"
                      prefWidth="240" minWidth="240" maxWidth="240">

                    <VBox spacing="8"
                          styleClass="drawer-nav"
                          fillWidth="true">
                        <VBox.margin>
                            <Insets top="0" right="0" bottom="0" left="0"/>
                        </VBox.margin>

                        <Button text="%drawer.settings" onAction="#openSettings" styleClass="drawer-item" maxWidth="Infinity"/>
                        <Button text="%drawer.editMode" onAction="#openEditMode" styleClass="drawer-item" maxWidth="Infinity"/>
                        <Button text="%drawer.about"    onAction="#openAbout"    styleClass="drawer-item" maxWidth="Infinity"/>

                        <Region VBox.vgrow="ALWAYS"/>

                        <!-- Language -->
                        <Button fx:id="btnLanguage"
                                text="%drawer.language"
                                onAction="#toggleLanguageChooser"
                                styleClass="drawer-item"
                                maxWidth="Infinity"/>

                        <VBox fx:id="languageRow"
                              spacing="8"
                              visible="false"
                              managed="false"
                              styleClass="drawer-theme-row">
                            <ComboBox fx:id="cbLanguage" styleClass="drawer-combo" maxWidth="Infinity" prefWidth="Infinity"/>
                        </VBox>

                        <!-- Theme -->
                        <Button fx:id="btnTheme"
                                text="%drawer.theme"
                                onAction="#toggleThemeChooser"
                                styleClass="drawer-item"
                                maxWidth="Infinity"/>

                        <HBox fx:id="themeRow"
                              spacing="10"
                              alignment="CENTER_LEFT"
                              visible="false"
                              managed="false"
                              styleClass="drawer-theme-row">
                            <ToggleSwitch fx:id="tgTheme"/>
                            <Label fx:id="lblTheme" text="%theme.dark" styleClass="drawer-theme-label"/>
                        </HBox>
                    </VBox>

                    <Region VBox.vgrow="ALWAYS"/>
                </VBox>

            </StackPane>
        </center>

        <!-- ================= FOOTER ================= -->
        <bottom>
            <VBox>
                <Region styleClass="ffooter-accent"/>
                <HBox styleClass="footer" spacing="10">
                    <Label fx:id="lblVersion" text="v0.0.0" styleClass="footer-left"/>
                    <Region HBox.hgrow="ALWAYS"/>
                </HBox>
            </VBox>
        </bottom>

    </BorderPane>
</StackPane>
